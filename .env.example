# NextAuth
# Generate a secret with: openssl rand -base64 32
# On Vercel, add this under Settings > Environment Variables.
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# Canonical URL of your deployment.
# Local dev: http://localhost:3000
# Vercel production: https://your-project.vercel.app  (or your custom domain)
# Vercel preview deployments: leave unset – Vercel sets VERCEL_URL automatically.
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App credentials
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL must be: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

# Optional: override OAuth scope. Default is: read:user public_repo
# Use read:user repo if you need to scan private repositories.
# GITHUB_OAUTH_SCOPE=read:user public_repo

# Optional Redis (Upstash) for shared cache/locks/rate limits.
# Either KV_* or UPSTASH_REDIS_REST_* names are supported.
KV_REST_API_TOKEN=your-upstash-token
KV_REST_API_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io

# Prefix used for Redis cache keys, locks, and rate limits.
# Set a different value per website if they share the same Upstash Redis account.
REDIS_KEY_PREFIX=github-branch-comparator
