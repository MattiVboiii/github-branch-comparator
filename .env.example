# NextAuth
# Generate a secret with: openssl rand -base64 32
# On Vercel, add this under Settings > Environment Variables.
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# Canonical URL of your deployment.
# Local dev: http://localhost:3000
# Vercel production: https://your-project.vercel.app  (or your custom domain)
# Vercel preview deployments: leave unset – Vercel sets VERCEL_URL automatically.
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App credentials
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL must be: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret
